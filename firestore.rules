rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && isOwner(userId));
    }

    // Active punches: clients read their own; writes only through Cloud Functions
    // (admin SDK bypasses these rules). Admins may manually clear stuck punches.
    match /activePunches/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow write: if isAdmin();
    }

    // Time entries
    match /timeEntries/{entryId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);

      // Admins: full control
      allow create, update, delete: if isAdmin();

      // Users: manual entries only — source and autoClockOut must not be set.
      // Clock-source writes go through Cloud Functions (admin SDK).
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && !('source' in request.resource.data)
        && !('autoClockOut' in request.resource.data);

      // Users delete their own non-approved entries (matches dashboard feature).
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && resource.data.status != 'approved';
    }

    // Audit log: admins read; writes only via Cloud Functions
    match /clockLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Availability
    match /availability/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}